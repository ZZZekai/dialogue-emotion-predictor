# Python caches
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/

# Environment variables and secrets
.env
.env.*
*.env
*.env.*
!.env.example
*.pem
*.key

# Sensitive datasets, database dumps, and spreadsheet materials
*.xlsx
*.xls
*.docx
*.doc
*.pdf
*.pptx
*.ppt
*.sql
*.csv
*.tsv
*.jsonl
*.ndjson
*.parquet
*.db
*.sqlite
*.sqlite3
*.dump
*.zip
*.7z
*.rar
~$*

# Generated outputs
outputs/*
!outputs/.gitkeep

# SQL dialogue converter materials and generated workbooks
tool/sql_dialogue_converter/input/*
!tool/sql_dialogue_converter/input/.gitkeep
tool/sql_dialogue_converter/output/*
!tool/sql_dialogue_converter/output/.gitkeep
tool/excel_comparison_merger/output/*
!tool/excel_comparison_merger/output/.gitkeep
tool/*_share.zip

# Downstream generation outputs
downstream/outputs/*
!downstream/outputs/.gitkeep
downstream/materials/*
!downstream/materials/.gitkeep

# Local data files
data/*
!data/.gitkeep

# Local model files
models/*
!models/.gitkeep

# Reference files from teammates
new_classification_standards/

# Internal presentation packages containing source data and case materials
成果/

# Local sensitive prompt materials
prompts/person_profile.txt
prompts/case_background.txt
prompts/emotion_examples.txt
!prompts/person_profile.example.txt
!prompts/case_background.example.txt
!prompts/emotion_examples.example.txt

# Local profile registry and sensitive story backgrounds
local_profiles/*
!local_profiles/.gitkeep

# IDE and OS files
.DS_Store
.idea/
.vscode/

# Logs
*.log
